{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_kind",
    "public_surface_target",
    "is_stateful",
    "has_io",
    "has_concurrency",
    "declared_state_count",
    "declared_transition_count",
    "declared_invariant_count",
    "test_obligation_class"
  ],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_kind": {"type": "string"},
    "public_surface_target": {"type": "integer", "minimum": 0},
    "is_stateful": {"type": "boolean"},
    "has_io": {"type": "boolean"},
    "has_concurrency": {"type": "boolean"},
    "declared_state_count": {"type": "integer", "minimum": 0},
    "declared_transition_count": {"type": "integer", "minimum": 0},
    "declared_invariant_count": {"type": "integer", "minimum": 0},
    "test_obligation_class": {"type": "string"}
  }
}
